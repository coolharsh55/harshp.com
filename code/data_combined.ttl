<https://harshp.com/research/projects/risky> a hpcom:RenderedItem,
        <https://harshp.com/research/projects>,
        schema:Project ;
    hpcom:acronym "RISKY" ;
    hpcom:competitive_funding true ;
    hpcom:content [ a hpcom:Content ;
            hpcom:contentFile "https://harshp.com/code/content/research/projects/risky/index.html" ;
            hpcom:contentFileFormat hpcom:formatHTML ] ;
    hpcom:funding_credit true ;
    hpcom:project_budget "91910"^^xsd:int ;
    hpcom:project_budget_award "91910"^^xsd:int ;
    hpcom:project_budget_control "91910"^^xsd:int ;
    hpcom:project_type "Postdoctoral Fellowship"@en ;
    schema:description "The RISKY project aims to enable exploration of privacy risks and its mitigations by storing information within a knowledge graph. This information consists of direct and indirect relationships between concepts associated with technologies, privacy risks, and their mitigations."@en ;
    schema:endDate "2022-09-30T00:00:00"^^xsd:dateTime ;
    schema:funding [ a schema:MonetaryGrant ;
            schema:funder [ a schema:FundingScheme ;
                    schema:funder [ a schema:FundingAgency ;
                            schema:name "Irish Research Council (IRC)"@en ;
                            schema:url "http://research.ie/"^^xsd:anyURI ] ;
                    schema:name "Government of Ireland Postdoctoral Fellowship Programme (GOIPD)"@en ;
                    schema:url "http://research.ie/funding/goipd/"^^xsd:anyURI ] ;
            schema:identifier "GOIPD/2020/790"^^xsd:string ;
            schema:recipient <https://harshp.com/me> ] ;
    schema:member [ a schema:Role ;
            schema:endDate "2022-09-30T00:00:00"^^xsd:dateTime ;
            schema:member <https://harshp.com/me> ;
            schema:roleName "Principal Investigator (PI)"@en ;
            schema:startDate "2020-10-01T00:00:00"^^xsd:dateTime ] ;
    schema:name "Exploring Privacy Risks of Technologies using Knowledge Graphs"@en ;
    schema:startDate "2020-10-01T00:00:00"^^xsd:dateTime ;
    schema:url "https://harshp.com/research/projects/risky"^^xsd:anyURI .

