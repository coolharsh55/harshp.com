book:40 a hpcom:Book,
        hpcom:BookReading,
        hpcom:RenderedItem,
        schema:Book ;
    hpcom:book_id hpcom:40 ;
    hpcom:book_owned_medium hpcom:EBook ;
    hpcom:book_read_medium hpcom:EBook ;
    hpcom:book_status hpcom:book-read ;
    hpcom:date_book_read "2025-07-15T00:00:00"^^xsd:dateTime ;
    schema:aggregatedRating hptag:Rating2 ;
    schema:author "Neal Stephenson" ;
    schema:dateCreated "2011"^^xsd:int ;
    schema:genre hpcom:BookFiction,
        hpcom:BookSciFi ;
    schema:name "Reamde" ;
    schema:review "Stephenson had some really crazy and intense ideas in the earlier books like Snow Crash and Cryptonomicon and Anathem. Then I found it less interesting in the later books, starting from Seven Eves and especially for Fall or Dodge in Hell. Reamde (I keep reading this as Readme!) is the previous book to Fall... I didn't like it. Its too abstract, too pretentious, and just goes too grandiose for the sake of it. I read the latest one (Termination Shock) before this, and I can see how the aspects that I didn't like are here and scattered but really amplified with each book. No more Stephenson for me."@en ;
    schema:url "https://harshp.com/hobbies/books/40"^^xsd:anyURI .

