        hpcom:RenderedItem,
        schema:Book ;
    hpcom:book_id hpcom:800 ;
    hpcom:book_owned_medium hpcom:PhysicalBook ;
    hpcom:book_read_medium hpcom:PhysicalBook ;
    hpcom:book_status hpcom:book-read ;
    hpcom:date_book_read "2022-05-15T00:00:00"^^xsd:dateTime ;
    schema:aggregatedRating hptag:Rating4 ;
    schema:author "Jen Gunter" ;
    schema:dateCreated "2019"^^xsd:int ;
    schema:genre hpcom:BookNonFiction ;
    schema:isPartOf list:educational ;
    schema:name "The Vagina Bible" ;
    schema:review "Undeniably educational, this book is a good collection of short chapters on various topics and issues and all sorts of things a woman (and a man, and everyone for that matter) could benefit from knowing. A lot of online reviews, e.g. goodreads, point out the tone of the book being too opionated or that this information can be found elsewhere. I don't understand them. Can you blame the author when history and even large swathes of the current society are ignorant of women and their bodies? I'm bitter about not knowing things that 50% of all humans have or are facing. And I don't even have a women's body. Despite this, I found the book to be educational, even if as a refresher to things, to know more about the crazy amount of issues women have to live with, every day every month, and that there are a lot of things that I should know about too."@en ;
    schema:url "https://harshp.com/hobbies/books/800"^^xsd:anyURI .

