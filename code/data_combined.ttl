    schema:aggregatedRating hptag:Rating4 ;
    schema:author "Travis Baldree" ;
    schema:dateCreated "2022"^^xsd:int ;
    schema:genre hpcom:BookFiction,
        hpcom:BookSciFi ;
    schema:isPartOf list:DublinLibrary ;
    schema:name "Legends & Lattes" ;
    schema:review "Comfort read in the style of DnD campaign shenanigans and cozy games where you level up a coffee shop (you've invented pastries! chocolate!) Set in a fantasy setting, this reminded me of the time I tried to introduce pizza in a remote setting and it was nice. The story itself is intentionally light and stress-free. Read it, relax, enjoy a cup of coffee."@en ;
    schema:url "https://harshp.com/hobbies/books/1073"^^xsd:anyURI .

