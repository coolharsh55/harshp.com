    hpcom:book_read_medium hpcom:EBook ;
    hpcom:book_status hpcom:book-read ;
    hpcom:date_book_read "2026-07-01T02:00:00"^^xsd:dateTime ;
    schema:aggregatedRating hptag:Rating4 ;
    schema:author "T. Kingfisher" ;
    schema:dateCreated "2022"^^xsd:int ;
    schema:genre hpcom:BookFiction,
        hpcom:BookSciFi ;
    schema:isPartOf list:DublinLibrary ;
    schema:name "Nettle & Bone" ;
    schema:review "Fantasy but touched with reality. Knowing more about the hard choices one makes, especially as a woman, really shapes the story beyond just magic and action or whatever typical things are. Really nicely put together. Enough nuance to have things be conscious but not enough to feel in your face or that it isn't part of the story. The ending was a bit of a rush, but it still was enjoyable. In a weird way reminded me of reading Earthsea series."@en ;
    schema:url "https://harshp.com/hobbies/books/1066"^^xsd:anyURI .

book:1067 a hpcom:Book,
        hpcom:BookReading,
        hpcom:RenderedItem,
