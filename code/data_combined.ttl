    schema:name "Enhancing Data Use Ontology (DUO) for Health-Data Sharing by Extending it with ODRL and DPV"@en ;
    schema:publisher <http://www.semantic-web-journal.net/> ;
    schema:url "https://doi.org/10.3233/SW-243583"^^xsd:anyURI .

