    hpcom:date_book_read "2022-12-24T00:00:00"^^xsd:dateTime ;
    schema:aggregatedRating hptag:Rating5 ;
    schema:author "Salman Rushdie" ;
    schema:dateCreated "1983"^^xsd:int ;
    schema:genre hpcom:BookFiction ;
    schema:isPartOf list:language ;
    schema:name "Shame" ;
    schema:review "A beatifully constructed prose that describes an observation of a culture's obsession with shame - and all that follows. I enjoyed the book right from the start, with all its weird pacings which go from intricate detailed expositions of a single picture to paragraphs that move time in decades. Perhaps I liked this so much because I could visualise the characters and the descriptions and could relate to them. Perhaps this was why I was not much impressed with Quichotte despite it containing the same beautifully written narrations."@en ;
    schema:url "https://harshp.com/hobbies/books/715"^^xsd:anyURI .

