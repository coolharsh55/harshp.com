    hpcom:date_book_read "2022-07-27T12:00:00"^^xsd:dateTime ;
    schema:aggregatedRating hptag:Rating2 ;
    schema:author "Jonas Jonasson" ;
    schema:dateCreated "2016"^^xsd:int ;
    schema:genre hpcom:BookFiction ;
    schema:name "Hitman Anders and the Meaning of it all" ;
    schema:review "The book starts off at a good spot. There's simple exposition, situational humour, and all the makings of a good recipie. By the end, it got boring, repetitive, the humour had all but become stale and there was nothing special anymore. A nice book if this had been half its length, or had spent some time on its characters instead of shuffling them from scene to scene."@en ;
    schema:url "https://harshp.com/hobbies/books/644"^^xsd:anyURI .

book:645 a hpcom:Book,
        hpcom:BookReading,
        hpcom:RenderedItem,
        schema:Book ;
    hpcom:book_id hpcom:645 ;
    hpcom:book_owned_medium hpcom:EBook ;
    hpcom:book_read_medium hpcom:EBook ;
    hpcom:book_status hpcom:book-read ;
    hpcom:date_book_read "2022-11-17T00:00:00"^^xsd:dateTime ;
    schema:aggregatedRating hptag:Rating3 ;
    schema:author "Bobby Duffy" ;
    schema:dateCreated "2018"^^xsd:int ;
    schema:genre hpcom:BookFiction,
        hpcom:BookSciFi ;
    schema:name "The Perils of Perception: Why We're Wrong About Nearly Everything" ;
    schema:review "Interesting, well-studied collection of how what we believe deviates from facts and that sharing those facts doesn't 'educate' us, but instead confirms out pre-existing distortions and biases. But, the book did not go too deep into these things, instead presenting anecdotes and rehashed arguments from other books. It is much more rewarding to read specific investigations, such as into politics, sexism, and social behaviours - which also inform about such distortions, but are more rewarding because they look at through the lens of causality."@en ;
    schema:url "https://harshp.com/hobbies/books/645"^^xsd:anyURI .

