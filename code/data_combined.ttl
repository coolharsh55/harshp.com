    schema:genre hpcom:BookFiction,
        hpcom:BookSciFi ;
    schema:name "The Seven Moons of Maali Almeida" ;
    schema:review "This is a clever book written with prose that is witty and implies wisdom in places without throwing it in the face. It is set in the Sri Lankan conflict, and without the cultural knowledge of the situation a lot of references and subtle nuances would be lost. I enjoyed reading it, even if the story itself was not particularly to my liking - but the writing style was rich and enjoyable."@en ;
    schema:url "https://harshp.com/hobbies/books/873"^^xsd:anyURI .

book:874 a hpcom:Book,
