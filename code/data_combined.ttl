<https://harshp.com/research/presentations#2016-EvalUMAP> a schema:PresentationDigitalDocument ;
    schema:about <https://harshp.com/research/publications/003-open-data-improve-readability-adaptability-personalisation> ;
    schema:category "Research Presentation"@en ;
    schema:datePublished "2016-07-16T10:00:00"^^xsd:dateTime ;
