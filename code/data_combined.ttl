book:555 a hpcom:Book,
        hpcom:BookReading,
        hpcom:RenderedItem,
        schema:Book ;
    hpcom:book_id hpcom:555 ;
    hpcom:book_owned_medium hpcom:PhysicalBook ;
    hpcom:book_read_medium hpcom:PhysicalBook ;
    hpcom:book_status hpcom:book-read ;
    hpcom:date_book_read "2020-02-28T00:00:00"^^xsd:dateTime ;
    schema:aggregatedRating hptag:Rating3 ;
    schema:author "Atul Gawande" ;
    schema:dateCreated "2009"^^xsd:int ;
    schema:genre hpcom:BookNonFiction ;
    schema:isPartOf list:DCU,
        list:books-changed-life ;
    schema:name "The Checklist Manifesto: How to Get Things Right" ;
    schema:review "Checklists work, they provide discipline, and are critical in complicated tasks such as surgery and flying a plane. That sums the book, though of course why checklists are needed, and how they are adopted and some good stories about their use is what makes the book a good read. Alas, I bought the book in the hope of using checklists for personal productivity - to which the book provides no clue or indication. Still, I will say this has been an enjoyable read if only so as to read about checklists used and being useful across the world."@en ;
    schema:url "https://harshp.com/hobbies/books/555"^^xsd:anyURI .

