    hpcom:book_id hpcom:947 ;
    hpcom:book_owned_medium hpcom:PhysicalBook ;
    hpcom:book_read_medium hpcom:PhysicalBook ;
    hpcom:book_status hpcom:book-read ;
    hpcom:date_book_read "2025-11-23T12:00:00"^^xsd:dateTime ;
    schema:aggregatedRating hptag:Rating5 ;
    schema:author "James Clear" ;
    schema:dateCreated "2018"^^xsd:int ;
    schema:genre hpcom:BookNonFiction ;
    schema:name "Atomic Habits: An Easy & Proven Way to Build Good Habits & Break Bad Ones" ;
    schema:review "Atomic Habits is a popular book about making habits in a methodological and structured manner and making it a part of you. The 'atomic' is a reference to 'units' i.e. building blocks rather than sweeping changes. The core ideas resonated with me because with big blocks you either do stuff or you fail, but with smaller blocks you still have the benefit of some of the structure being in place and then benefitting from not having to restart from scratch. I read the book twice, but didn't want to mark it read the first time around because I knew that if I were to benefit from it, I have to give it some time, and then go back and make detailed notes for how I want to use the book. Good book. Recommended."@en ;
    schema:url "https://harshp.com/hobbies/books/947"^^xsd:anyURI .

