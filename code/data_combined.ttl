book:759 a hpcom:Book,
        hpcom:BookReading,
        hpcom:RenderedItem,
        schema:Book ;
    hpcom:book_id hpcom:759 ;
    hpcom:book_owned_medium hpcom:PhysicalBook ;
    hpcom:book_read_medium hpcom:PhysicalBook ;
    hpcom:book_status hpcom:book-read ;
    hpcom:date_book_read "2022-12-10T00:00:00"^^xsd:dateTime ;
    schema:aggregatedRating hptag:Rating3 ;
    schema:author "Carlo Rovelli" ;
    schema:dateCreated "2021"^^xsd:int ;
    schema:genre hpcom:BookNonFiction ;
    schema:isPartOf list:DCU,
        list:GiveAway ;
    schema:name "Helgoland: The World of Quantum Theory" ;
    schema:review "There's no illusions that this book is written by someone who can explain quantum physics in the manner of a nice lecture. Unfortunately, this is exactly what the book comes off as. Excellent start, some hand waving of concepts that should have chapters dedicated to explanation, and then complete derailment towards things that are relevant but not on the topic. When the book is this thin, every page has to offer more. All this said, the book did offer new perspectives, but didn't make good descriptions out of them."@en ;
    schema:url "https://harshp.com/hobbies/books/759"^^xsd:anyURI .

