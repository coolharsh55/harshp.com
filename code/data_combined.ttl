book:1000 a hpcom:Book,
        hpcom:BookReading,
        hpcom:RenderedItem,
        schema:Book ;
    hpcom:book_id hpcom:1000 ;
    hpcom:book_owned_medium hpcom:PhysicalBook ;
    hpcom:book_read_medium hpcom:PhysicalBook ;
    hpcom:book_status hpcom:book-read ;
    hpcom:date_book_read "2026-02-15T00:00:00"^^xsd:dateTime ;
    schema:aggregatedRating hptag:Rating3 ;
    schema:author "" ;
    schema:dateCreated "2020"^^xsd:int ;
    schema:genre hpcom:BookFiction ;
    schema:name "Hamnet" ;
    schema:review "A book about Shakespear. Quite unlike what I was expecting as this was a more gentle foray into a family, aware of prying but also desiring to share the state of things without focusing on the one man that became popular. I thought the story was quite sad, though entirely realistic and grounded, if that's even a sensible description. I picked up the book because this was the last book a dear friend was reading before their persistent absence, and I did not like that things had been left unfinished and unknown. I'm a little more at peace after finishing the book, which considering the story, I felt a strange emotional connection to as well. I know there is a move about the same, but I do not think I would want to watch it right away. Or ever. The book has been enough."@en ;
    schema:url "https://harshp.com/hobbies/books/1000"^^xsd:anyURI .

