    schema:author "Claire Keegan" ;
    schema:dateCreated "2021"^^xsd:int ;
    schema:genre hpcom:BookFiction ;
    schema:name "Small Things Like These" ;
    schema:review "An anti-Christmas carol, this is a story about a decent man finding a woman in distress in one of the Magdalene laundries. The book itself is small, and the writing flowing and episodic. It is a good book. Something to consider that the spirit of things is in our deeds more than the abstract notions of religion or celebration or any other thing. If you do not act, then you are not good."@en ;
    schema:url "https://harshp.com/hobbies/books/999"^^xsd:anyURI .

list:best-rated a hpcom:RenderedItem,
        book:lists ;
    hpcom:renderWith [ a hpcom:View ;
            hpcom:sparql [ a hpcom:SparqlQuery ;
                    rdfs:label "books" ;
                    hpcom:queryString """
                    SELECT DISTINCT ?book ?name (MAX(?date) as ?dt) WHERE {
                        ?book a schema:Book .
                        ?book schema:name ?name .
                        ?book hpcom:date_book_read ?date .
                        ?book schema:aggregatedRating hpcom:Rating5 .
                    } GROUP BY ?book ORDER By DESC(?dt) ASC(?name) 
                    """ ] ;
            hpcom:view_renderer hpcom:Jinja2 ;
            hpcom:view_template "https://harshp.com/code/templates/template_hobbies_book_list.jinja2" ] ;
    schema:identifier "best-rated"@en ;
    schema:name "Best Books by Rating"@en .

list:loaned a hpcom:RenderedItem,
        book:lists ;
    hpcom:renderWith [ a hpcom:View ;
            hpcom:sparql [ a hpcom:SparqlQuery ;
                    rdfs:label "books" ;
                    hpcom:queryString """
                    SELECT DISTINCT ?book ?name (MAX(?date) as ?dt) WHERE {
                        ?book a schema:Book .
                        ?book schema:name ?sname .
                        ?book schema:dateCreated ?date .
                        ?book hpcom:book_on_loan ?whom .
                        BIND(CONCAT(" -- ", ?sname) as ?tname) .
                        BIND(CONCAT(?whom, ?tname) as ?name) .
                    } GROUP BY ?book ORDER By ASC(?name) ASC(?sname) 
                    """ ] ;
            hpcom:view_renderer hpcom:Jinja2 ;
            hpcom:view_template "https://harshp.com/code/templates/template_hobbies_book_list.jinja2" ] ;
    schema:identifier "loaned"@en ;
    schema:name "Loaned Books"@en .

list:owned a hpcom:RenderedItem,
        book:lists ;
    hpcom:renderWith [ a hpcom:View ;
            hpcom:sparql [ a hpcom:SparqlQuery ;
                    rdfs:label "books" ;
                    hpcom:queryString """
                    SELECT DISTINCT ?book ?name (MAX(?date) as ?dt) WHERE {
                        ?book a schema:Book .
                        ?book schema:name ?name .
                        ?book hpcom:book_owned_medium ?medium .
                        BIND(?datePublished as ?date) .
                        OPTIONAL { 
                            ?book hpcom:date_book_read ?dateRead .
                            BIND(?dateRead as ?date) .
                        }
                    } GROUP BY ?book ORDER By DESC(?dt) ASC(?name) 
                    """ ] ;
            hpcom:view_renderer hpcom:Jinja2 ;
            hpcom:view_template "https://harshp.com/code/templates/template_hobbies_book_list.jinja2" ] ;
    schema:identifier "owned"@en ;
    schema:name "Owned Books"@en .

