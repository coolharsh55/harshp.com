    hpcom:view_renderer hpcom:Jinja2 ;
    hpcom:view_template "https://harshp.com/code/templates/template_stories_index.jinja2" .

hpview:StoryView a hpcom:View ;
    hpcom:view_renderer hpcom:Jinja2 ;
    hpcom:view_target <https://harshp.com/stories> ;
