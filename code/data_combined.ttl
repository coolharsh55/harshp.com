        schema:Book ;
    hpcom:book_id hpcom:978 ;
    hpcom:book_owned_medium hpcom:PhysicalBook ;
    hpcom:book_read_medium hpcom:PhysicalBook ;
    hpcom:book_status hpcom:book-read ;
    hpcom:date_book_read "2025-02-15T23:00:00"^^xsd:dateTime ;
    schema:aggregatedRating hptag:Rating5 ;
    schema:author "Stephen Fry" ;
    schema:dateCreated "2017"^^xsd:int ;
    schema:genre hpcom:BookNonFiction ;
    schema:name "Mythos: The Greek Myths Retold" ;
    schema:review "The Greek mythology is fascinating not only because of its rich characterisation and drama, but also because at the heart of all stories is the core of a philosophy that makes describing humans an exercise in the interpretation of the divine. Greek gods - the mythos - are structured around the facets of human emotions, virtues, aspects, and so much more. I greatly respect Stephen Fry as a narrator, orator, and as a person who knows to focus on being decent above political correctness and style. This book is a fantastic recollection of the greek mythos - covering a lot in such a small space and making it enjoyable. I borrowed this book from our neighbour - and it has been fantastic reading it."@en ;
    schema:url "https://harshp.com/hobbies/books/978"^^xsd:anyURI .

