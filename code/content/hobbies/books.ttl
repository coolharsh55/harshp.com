    schema:genre hpcom:BookFiction,
        hpcom:BookSciFi ;
    schema:name "Lives of Bitter Rain" ;
    schema:review "A short novella set in the same world as the rest of tyrant philosphers. This is basically a mini version of things, with more events, more weird things, more tragedy, and a more tacit reminder of where our society is slipping."@en ;
