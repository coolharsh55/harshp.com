<https://harshp.com/hobbies/books/1024> a hpcom:Book,
        hpcom:BookReading,
        hpcom:RenderedItem,
        schema:Book ;
    hpcom:book_id hpcom:1024 ;
    hpcom:book_owned_medium hpcom:EBook ;
    hpcom:book_read_medium hpcom:EBook ;
    hpcom:book_status hpcom:book-read ;
    hpcom:date_book_read "2026-04-20T00:00:00"^^xsd:dateTime ;
    schema:aggregatedRating hptag:Rating5 ;
    schema:author "Adrian Tchaikovsky" ;
    schema:dateCreated "2021"^^xsd:int ;
    schema:genre hpcom:BookFiction,
        hpcom:BookSciFi ;
    schema:name "One day all this will be yours" ;
    schema:review "I thought this novel would be the same style and setting as the previous one, which was absoluitely thrilling (walking to alderbaran). Imagine the surprise when the book starts off as a time traveller story, and a funny one at that. Totally unexpected from the author, which made the delight even more delightful. I would have expected this from Charles Stross maybe, but really hats off to stretching the imagination and fun here."@en ;
    schema:url "https://harshp.com/hobbies/books/1024"^^xsd:anyURI .

