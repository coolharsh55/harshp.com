    hpcom:book_status hpcom:book-read ;
    hpcom:date_book_read "2024-10-07T00:00:00"^^xsd:dateTime ;
    schema:aggregatedRating hptag:Rating4 ;
    schema:author "Nancy Fraser" ;
    schema:dateCreated "2022"^^xsd:int ;
    schema:genre hpcom:BookNonFiction ;
    schema:name "Cannibal Capitalism: How our System is Devouring Democracy, Care, and the Planet—and What We Can Do About It" ;
    schema:review "I learnt a great deal from this book about the history of capitalism, and why those who don't know their history are bound to repeat it. Towards the end of the book, it became less apparent what I was learning, but I think this is a good book to pick up and go through to understand the current state of things and the inner workings of governments and the governed."@en ;
    schema:url "https://harshp.com/hobbies/books/862"^^xsd:anyURI .

<https://harshp.com/hobbies/books/863> a hpcom:Book,
        hpcom:BookReading,
        hpcom:RenderedItem,
        schema:Book ;
    hpcom:book_id hpcom:863 ;
