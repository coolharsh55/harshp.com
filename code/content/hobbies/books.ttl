    hpcom:book_read_medium hpcom:PhysicalBook ;
    hpcom:book_status hpcom:book-read ;
    hpcom:date_book_read "2025-02-14T00:00:00"^^xsd:dateTime ;
    schema:aggregatedRating hptag:Rating5 ;
    schema:author "Jostein Gaarder" ;
    schema:dateCreated "1991"^^xsd:int ;
    schema:genre hpcom:BookFiction ;
    schema:name "Sophie's World" ;
    schema:review "I really wish I had read this book when I was in school. It would have been fantastic and it would have changed my life. The idea of introducing philosophy in such as simple but thorough manner is amazing and really creative. And the story within the story adds a nice break from it being a book about dry philosophy. Very much enjoyed it. I have a copy of Bertrand Russell's History of Western Philosophy on my shelf which this book is supposed to summarise. I look forward to going through it with rigour."@en ;
    schema:url "https://harshp.com/hobbies/books/971"^^xsd:anyURI .

