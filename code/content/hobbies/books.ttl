<https://harshp.com/hobbies/books/1075> a hpcom:Book,
        hpcom:BookReading,
        hpcom:RenderedItem,
        schema:Book ;
    hpcom:book_id hpcom:1075 ;
    hpcom:book_owned_medium hpcom:PhysicalBook ;
    hpcom:book_read_medium hpcom:PhysicalBook ;
    hpcom:book_status hpcom:book-read ;
    hpcom:date_book_read "2026-07-16T04:00:00"^^xsd:dateTime ;
    schema:aggregatedRating hptag:Rating4 ;
    schema:author "James Islington" ;
    schema:dateCreated "2023"^^xsd:int ;
    schema:genre hpcom:BookFiction,
        hpcom:BookSciFi ;
    schema:name "The Will of the Many" ;
    schema:review "A large book, at 700 pages, but thoroughly entertaining. It felt like a weird mash-up of hunger games, harry potter, Chronicles, and many others. Still intriguing. The most interesting part was the way that Will works and the necessity of its flow to maintain governance. The setting of the Roman empire was also interesting. It straddles science and without spoiling the end, quite a lot, but the book is based on fantasy tropes. The most annoying one is how the protagonist seems to simply 'level up' and can do everything better than everyone else with little practice and ability. "@en ;
    schema:url "https://harshp.com/hobbies/books/1075"^^xsd:anyURI .

