    schema:aggregatedRating hptag:Rating5 ;
    schema:author "Karen Hao" ;
    schema:dateCreated "2025"^^xsd:int ;
    schema:genre hpcom:BookNonFiction ;
    schema:name "Empire of AI: Dreams and Nightmares in Sam Altman's OpenAI" ;
    schema:review "A seminal work from a reputed journalist, this book really explores the rise of OpenAI and tells a story that bares the reality of chaos. Essential reading for those working in this field."@en ;
    schema:url "https://harshp.com/hobbies/books/1053"^^xsd:anyURI .

