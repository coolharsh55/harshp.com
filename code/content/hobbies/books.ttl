    hpcom:book_read_medium hpcom:EBook ;
    hpcom:book_status hpcom:book-read ;
    hpcom:date_book_read "2023-01-05T19:00:00"^^xsd:dateTime ;
    schema:aggregatedRating hptag:Rating3 ;
    schema:author "Sue Burke" ;
    schema:dateCreated "2018"^^xsd:int ;
    schema:genre hpcom:BookFiction,
        hpcom:BookSciFi ;
    schema:name "Semiosis" ;
    schema:review "An interesting premise - what if alient plants were sentient and how would we know and how would we react and what kind of conversations we could have. But then the execution fizzled out and this turned out to just be a what-if type book rather than a detailed study that would have made excellent hard-fiction."@en ;
    schema:url "https://harshp.com/hobbies/books/783"^^xsd:anyURI .

