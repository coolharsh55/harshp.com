<https://harshp.com/hobbies/books/557> a hpcom:Book,
        hpcom:BookReading,
        hpcom:RenderedItem,
        schema:Book ;
    hpcom:book_id hpcom:557 ;
    hpcom:book_owned_medium hpcom:PhysicalBook ;
    hpcom:book_read_medium hpcom:PhysicalBook ;
    hpcom:book_status hpcom:book-read ;
    hpcom:date_book_read "2020-11-30T00:00:00"^^xsd:dateTime ;
    schema:aggregatedRating hptag:Rating4 ;
    schema:author "Liz Elvidge" ;
    schema:dateCreated "2017"^^xsd:int ;
    schema:genre hpcom:BookNonFiction ;
    schema:isPartOf hplist:books-changed-life ;
    schema:name "What Every Postdoc Needs To Know" ;
    schema:review "A lot of stuff presented in the book may seem like common-sense and common-advice so prevalent in academia, but the impact and coherent view really puts everything in perspective together. There are lists, checklists, and areas where you are asked to stop and think before moving ahead. This book presents a great exercise in shaping the postdoc career from the start and is a good reference to keep coming back to in the first two years. Receiving this at the end of my PhD was a delightful (and useful) gift. That said, I would go ahead and recommend this to PhDs who are curious about careers in academia and want to move on the becoming a postdoc."@en ;
    schema:url "https://harshp.com/hobbies/books/557"^^xsd:anyURI .

<https://harshp.com/hobbies/books/558> a hpcom:Book,
