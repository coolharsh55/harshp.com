<https://harshp.com/hobbies/books/806> a hpcom:Book,
        hpcom:BookReading,
        hpcom:RenderedItem,
        schema:Book ;
    hpcom:book_id hpcom:806 ;
    hpcom:book_owned_medium hpcom:PhysicalBook ;
    hpcom:book_read_medium hpcom:PhysicalBook ;
    hpcom:book_status hpcom:book-read ;
    hpcom:date_book_read "2023-10-27T00:00:00"^^xsd:dateTime ;
    schema:aggregatedRating hptag:Rating5 ;
    schema:author "Ari Ezra Waldman" ;
    schema:dateCreated "2021"^^xsd:int ;
    schema:genre hpcom:BookNonFiction ;
    schema:isPartOf hplist:DCU,
        hplist:books-changed-life,
        hplist:educational ;
    schema:name "Industry Unbound: The Inside Story of Privacy, Data, and Corporate Power" ;
    schema:review "An immensely well written narrative about the disparity between statements made by companies regarding privacy, the reputation and known intentions of privacy professionals, and the disproportionate gap between statement and action. The book is based on interviews with actual practioners in the industry and offers an excellent and necessary perspective on the 'other side'. Bottom line - there is a distinct lack of operational culture and people with needed roles don't have any say or power to make the changes. Regulations are superficial because they are drafted outside-in and promote checkboxes and internal responsibility - which as the book evidently and abundantly shows - is a repeated pattern of not working as intended. This book has been influential in making my research more informed and aware of the challenges in this area."@en ;
    schema:url "https://harshp.com/hobbies/books/806"^^xsd:anyURI .

