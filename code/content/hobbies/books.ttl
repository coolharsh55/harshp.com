<https://harshp.com/hobbies/books/1013> a hpcom:Book,
        hpcom:BookReading,
        hpcom:RenderedItem,
        schema:Book ;
    hpcom:book_id hpcom:1013 ;
    hpcom:book_owned_medium hpcom:PhysicalBook ;
    hpcom:book_read_medium hpcom:PhysicalBook ;
    hpcom:book_status hpcom:book-read ;
    hpcom:date_book_read "2026-05-31T00:00:00"^^xsd:dateTime ;
    schema:aggregatedRating hptag:Rating3 ;
    schema:author "Liz Pelly" ;
    schema:dateCreated "2025"^^xsd:int ;
    schema:genre hpcom:BookNonFiction ;
    schema:name "Mood Machine: The Rise of Spotify and the Costs of the Perfect Playlist" ;
    schema:review "The book explains the story of Spotify, its capitalist background, and the impact it is having. While illuminating and educating (e.g. I didn't know the extent of spotify's ad origins) the book feels as if it has already selected the direction of what it wants to go towards and doesn't care if the reader wants to follow. Yes, I understand that companies like spotify have a huge amount of impact, and a lot of it may not be moral or good. So this is more a reflection on the structure and the writing."@en ;
    schema:url "https://harshp.com/hobbies/books/1013"^^xsd:anyURI .

