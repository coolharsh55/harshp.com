    schema:dateCreated "1993"^^xsd:int ;
    schema:genre hpcom:BookFiction,
        hpcom:BookSciFi ;
    schema:name "Harvest of Stars" ;
    schema:review "Got this as a small pulp scifi book hoping there would be something interesting. Unfortunately, the writing is a slog, and even if the story has hints of Heinlein in themes of authority, moon, pursuit, and other themes surrounding AI and colonising exoplanets, it wasn't enough to be entertaining."@en ;
    schema:url "https://harshp.com/hobbies/books/975"^^xsd:anyURI .

<https://harshp.com/hobbies/books/976> a hpcom:Book,
