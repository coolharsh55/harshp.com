<https://harshp.com/hobbies/books/1032> a hpcom:Book,
        hpcom:BookReading,
        hpcom:RenderedItem,
        schema:Book ;
    hpcom:book_id hpcom:1032 ;
    hpcom:book_owned_medium hpcom:PhysicalBook ;
    hpcom:book_read_medium hpcom:PhysicalBook ;
    hpcom:book_status hpcom:book-read ;
    hpcom:date_book_read "2026-07-05T11:00:00"^^xsd:dateTime ;
    schema:aggregatedRating hptag:Rating5 ;
    schema:author "Alejandro Zambra" ;
    schema:dateCreated "2026"^^xsd:int ;
    schema:genre hpcom:BookFiction ;
    schema:name "Bonsai" ;
    schema:review "The patent blue Fitzcaraldo edition cover having caught my eye, I flicked the book open to see what new experiences might await me. The opening paragraph of this book hooked me immediately. A short book, I purchased it immediately. On a sunday morning, between coffee and breakfast, I finished all of it. It could have been 1000 pages to tell the same story, but the author reminded us with every few pages -- some things don't matter. Rarely can a talent cut across the essence of that story and deliver it like this. And that is what you are left with after -- just the essence. Not the body, which gives you a feeling of being full or having done a lot nor tiredness. This is the second book from the author and I think I will definitely want to serendipitously come across another some years in the future."@en ;
    schema:url "https://harshp.com/hobbies/books/1032"^^xsd:anyURI .

