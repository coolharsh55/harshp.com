    schema:dateCreated "2018"^^xsd:int ;
    schema:genre hpcom:BookFiction,
        hpcom:BookSciFi ;
    schema:name "Binti: The Night Masquerade" ;
    schema:review "I did not want to read this because I barely liked the first book and didn't like the second book, but I had purchased the third one - so I went through it expecting to not like it. Despite these low expectations, I still found it uninteresting, cliche, and apart from the 'interesting' aspect of being rooted in a different culture (tribal from Afria) there was nothing else that I found interesting."@en ;
    schema:url "https://harshp.com/hobbies/books/837"^^xsd:anyURI .

