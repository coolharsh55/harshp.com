    hpcom:book_status hpcom:book-read ;
    hpcom:date_book_read "2026-02-27T00:00:00"^^xsd:dateTime ;
    schema:aggregatedRating hptag:Rating5 ;
    schema:author "Emily M. Bender and Alex Hanna" ;
    schema:dateCreated "2025"^^xsd:int ;
    schema:genre hpcom:BookNonFiction ;
    schema:name "The AI Con: How to Fight Big Tech's Hype and Create the Future We Want" ;
    schema:review "An excellent book that explains, with the rigour of an academic and the patience of a public speaker, the background, working, and problems associated with the AI industry. Given that the authors are highly respected academics, there is indeed a plethora of informed opinions and references that build the case without overwhelming things. Definitely educational and timely."@en ;
    schema:url "https://harshp.com/hobbies/books/1001"^^xsd:anyURI .

