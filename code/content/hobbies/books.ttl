    schema:aggregatedRating hptag:Rating4 ;
    schema:author "Cory Doctorow" ;
    schema:dateCreated "2013"^^xsd:int ;
    schema:genre hpcom:BookFiction,
        hpcom:BookSciFi ;
    schema:isPartOf hplist:cork ;
    schema:name "Homeland" ;
    schema:review "This was scary to read because it might as well be what's happening out there. Not so much the actual sinister stuff, but the systemic normalisation of authoritative surveillance and the vast potential for it to become a norm that we shrug and live with because we're too complacent to do something."@en ;
    schema:url "https://harshp.com/hobbies/books/721"^^xsd:anyURI .

