    schema:genre hpcom:BookFiction,
        hpcom:BookSciFi ;
    schema:name "His Master's Voice" ;
    schema:review "Interesting book which goes through the human side of things were we to find an alien signal. The perspectives and arguments that are explored in the book are good reading. In what I now consider the classic Lem style - the book goes through our arrogance in not understanding the limitations of our own collective consciousness."@en ;
    schema:url "https://harshp.com/hobbies/books/931"^^xsd:anyURI .

