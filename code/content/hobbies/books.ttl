    schema:dateCreated "2024"^^xsd:int ;
    schema:genre hpcom:BookFiction,
        hpcom:BookSciFi ;
    schema:name "Lake of Souls" ;
    schema:review "This book contains a few independent stoties, and a few stories from the Raadchair and Raven Tower universe. I really liked the stories set in the existing novels. The independent ones were okay - but I really enjoyed reading more about the crazy world of the gods, and the tea-addicted Raadchai. Would have given this a rating of 5 quite easily had the entire book been about these stories. Good stuff overall."@en ;
    schema:url "https://harshp.com/hobbies/books/939"^^xsd:anyURI .

